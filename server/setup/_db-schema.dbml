Table friend {
  id int [pk, increment]
  accepted_on timestamp [note: 'Aceitado Em']
  friend_id int [not null, ref: > people.id, note: 'Amigo']
  people_id int [not null, ref: > people.id, note: 'Pessoa']
  request_on timestamp [not null, note: 'Pedido Em']
  Note: 'Amigo'
}

Table message {
  id int [pk, increment]
  from_people_id int [not null, ref: > people.id, note: 'De']
  message text [note: 'Mensagem']
  read_on timestamp [note: 'Lido Em']
  sent_on timestamp [not null, note: 'Enviado Em']
  to_people_id int [not null, ref: > people.id, note: 'Para']
  Note: 'Mensagem'
}

Table people {
  id int [pk, increment]
  avatar text [note: 'Avatar']
  email varchar(250) [unique, note: 'Email']
  name varchar(250) [not null, note: 'Nome']
  people_user_id int [not null, unique, note: 'Utilizador']
  recovery_key varchar(250) [note: 'Chave de Recuperação']
  recovery_limit timestamp [note: 'Limite de Recuperação']
  Note: 'Pessoa'
}

Table people_ws_session {
  id int [pk, increment]
  people_id int [not null, ref: > people.id, note: 'Pessoa']
  session_id varchar(250) [not null, note: 'Sessão ID']
  Note: 'WS Sessão'
}

